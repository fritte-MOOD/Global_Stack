// Prisma Schema — SQLite (wechselbar auf PostgreSQL)
//
// Top-Level Entitäten:
//   Group  — Community/Server. Kann Untergruppen enthalten (beliebig tief).
//   User   — Nutzer mit Profil. Kann in beliebig vielen Gruppen/Servern sein.
//
// Innerhalb von Group:
//   Untergruppen (= Groups mit parentId)
//   Event, Task, Document, Process
//
// Innerhalb von User:
//   Membership (Rolle pro Gruppe), Message, Profil-Felder
//
// Process ersetzt Debate — wird später ausgebaut wenn wir Deliberation bauen.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ═══════════════════════════════════════════
// USER
// ═══════════════════════════════════════════

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String?
  isDemo       Boolean  @default(false)
  email        String?
  name         String
  nickname     String?
  avatarUrl    String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships  Membership[]
  messages     Message[]
  tasks        Task[]     @relation("TaskAssignee")
  createdTasks Task[]     @relation("TaskCreator")
  documents    Document[]
  processes    Process[]
  sessions     Session[]
  
  createdEvents    Event[]           @relation("EventCreator")
  eventInvitations EventInvitation[]
  comments         Comment[]
  reactions        Reaction[]
  chatParticipants ChatParticipant[]
}

// ═══════════════════════════════════════════
// SESSION (Auth)
// ═══════════════════════════════════════════

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════
// GROUP (Server / Community / Untergruppe)
// ═══════════════════════════════════════════

model Group {
  id       String @id @default(cuid())
  slug     String @unique
  name     String
  subtitle String
  color    String
  icon     String

  // Hierarchie: null = Top-Level Server, gesetzt = Untergruppe
  // Untergruppen können selbst wieder Untergruppen haben (beliebig tief)
  parentId String?
  parent   Group?  @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Group[] @relation("GroupHierarchy")

  // "public" | "private" | "hidden"
  visibility String @default("public")

  // Template-System
  isTemplate          Boolean @default(false)
  templateDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  messages    Message[]
  events      Event[]
  tasks       Task[]
  documents   Document[]
  processes   Process[]
  chats       Chat[]
}

// ═══════════════════════════════════════════
// MEMBERSHIP (User ↔ Group)
// ═══════════════════════════════════════════

model Membership {
  id       String   @id @default(cuid())
  role     String   @default("member") // "admin" | "moderator" | "member" | "guest"
  joinedAt DateTime @default(now())

  userId  String
  groupId String
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

// ═══════════════════════════════════════════
// GROUP CONTENT
// ═══════════════════════════════════════════

model Message {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  authorId String
  groupId  String?
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  chatId String?
  chat   Chat?  @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String   @id @default(cuid())
  type      String   // "group" | "direct"
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  participants ChatParticipant[]
  messages     Message[]
}

model ChatParticipant {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  chatId String
  userId String
  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  groupId   String
  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  creatorId String
  creator   User  @relation("EventCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  invitations EventInvitation[]
  comments    Comment[]
}

// ═══════════════════════════════════════════
// EVENT INVITATIONS (Einladungen mit RSVP)
// ═══════════════════════════════════════════

model EventInvitation {
  id        String   @id @default(cuid())
  status    String   @default("pending") // "pending" | "accepted" | "declined" | "maybe"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

// ═══════════════════════════════════════════
// COMMENTS (für Events, später auch Tasks etc.)
// ═══════════════════════════════════════════

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Polymorphe Zuordnung: Comment kann zu Event gehören (später auch Task, Document, etc.)
  eventId String?
  event   Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Antworten (Unterkommentare)
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  reactions Reaction[]
}

// ═══════════════════════════════════════════
// REACTIONS (Emoji-Reaktionen auf Kommentare)
// ═══════════════════════════════════════════

model Reaction {
  id        String   @id @default(cuid())
  emoji     String   // z.B. "👍", "❤️", "😂", "🎉", "😢", "😡"
  createdAt DateTime @default(now())

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  done        Boolean   @default(false)
  dueAt       DateTime?
  createdAt   DateTime  @default(now())

  groupId    String
  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId  String
  creator    User   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId  String
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  authorId String
  author   User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Platzhalter — wird ausgebaut wenn wir Deliberation bauen.
// Dann kommen Module, Schritte, Abstimmungen, etc. hinzu.
model Process {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("draft") // "draft" | "active" | "completed" | "archived"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  groupId  String
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  authorId String
  author   User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
